# RailPVC backend environment — placeholders only. NEVER commit real values.
#
# Copy to backend/.env and fill from your Supabase project dashboard.
# backend/.env is git-ignored (.gitignore: `.env`, `*.env`).
# If a real secret is ever committed: rotate immediately, purge from git, log in SESSION_LOG.md.

# Supabase API hostname (NOT the dashboard URL). Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon JWT — used by backend for JWT signature verification (HS256 via JWT_SECRET below).
# Safe to surface to clients.
SUPABASE_ANON_KEY=your-anon-jwt-here

# Service-role JWT — bypasses RLS. Used ONLY by Alembic migrations and seed scripts.
# Never exposed to clients. Never used by tenant-facing request paths (see backend/api/* —
# tenant routes derive tenant_id from the caller's JWT and filter explicitly).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# Supabase JWT signing secret (Project Settings → API → JWT Secret).
# Used to verify Bearer tokens on every protected route.
SUPABASE_JWT_SECRET=your-jwt-signing-secret

# Direct Postgres connection — used by Alembic migrations and admin/seed scripts only.
# Format: postgresql+asyncpg://postgres.<project-ref>:<urlencoded-password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-url-encoded-password@your-region.pooler.supabase.com:5432/postgres
